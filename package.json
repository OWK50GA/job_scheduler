{
  "name": "job_scheduler",
  "private": true,
  "version": "1.0.0",
  "description": "Background Job scheduler",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:server": "tsc",
    "dev:server": "tsx watch --watch src src/index.ts",
    "dev:worker": "tsx watch --watch src/worker src/worker/index.ts",
    "start:server": "node dist/index.js",
    "dev:ui": "pnpm --filter ui run dev",
    "install:ui": "pnpm --filter ui install",
    "format": "prettier --write .",
    "seed:db": "tsx src/scripts/seeder.ts",
    "reset:db": "tsx src/scripts/reset-db.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
