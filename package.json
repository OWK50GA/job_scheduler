{
  "name": "job_scheduler",
  "private": true,
  "version": "1.0.0",
  "description": "Background Job scheduler",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:server": "tsc",
    "build:ui": "pnpm --filter ui build",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "dev:server": "tsx watch --watch src src/index.ts",
    "dev:worker": "tsx watch --watch src/worker src/worker/index.ts",
    "dev:ui": "pnpm --filter ui run dev",
    "start:server": "node dist/index.js",
    "start:worker": "node dist/worker/index.js",
    "start:ui": "pnpm --filter ui run start",
    "install:ui": "pnpm --filter ui install",
    "format": "prettier --write .",
    "seed:db": "tsx src/scripts/seeder.ts",
    "reset:db": "tsx src/scripts/reset-db.ts",
    "validate": "pnpm run lint && pnpm format && pnpm test && pnpm build:server",
    "debug:run": "pnpm tsx src/scripts/debug-run.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^6.1.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "jiti": "^2.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
